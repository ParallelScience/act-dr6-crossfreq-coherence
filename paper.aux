\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-channel coherence diagnostics for pa4\_f220 paired with pa5\_f090 (left), pa4\_f150 (center), and pa6\_f150 (right). Salmon shaded regions indicate the stability window $500\lesssim \ell \lesssim 1000$. Foreground-driven decoherence dominates at high~$\ell $, confirming that 220-related comparisons serve as correlation diagnostics rather than equal-spectrum tests.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:220diagnostics}{{4}{7}{Cross-channel coherence diagnostics for pa4\_f220 paired with pa5\_f090 (left), pa4\_f150 (center), and pa6\_f150 (right). Salmon shaded regions indicate the stability window $500\lesssim \ell \lesssim 1000$. Foreground-driven decoherence dominates at high~$\ell $, confirming that 220-related comparisons serve as correlation diagnostics rather than equal-spectrum tests}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Recommended stability windows for each pair type. Horizontal bars show the multipole range over which each pair type yields interpretable coherence diagnostics. Dashed and dotted vertical lines mark the cross-family ($\ell =1200$) and same-band ($\ell =1500$) scale cuts, respectively.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:recommendations}{{5}{7}{Recommended stability windows for each pair type. Horizontal bars show the multipole range over which each pair type yields interpretable coherence diagnostics. Dashed and dotted vertical lines mark the cross-family ($\ell =1200$) and same-band ($\ell =1500$) scale cuts, respectively}{figure.5}{}}
